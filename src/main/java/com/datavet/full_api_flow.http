# Paso 1 para registrarnos en la app:
#   Pediremos solamente los siguientes datos:
#       - clinicName    : String
#       - firstName     : String
#       - lastName      : String
#       - email         : String
#       - phone         : String
#       - password      : String
#
#   Una vez ejecutado esto, nos aparecerá en la consola un mensaje de Email de verificación con un Token
#   Dicho Token lo debemos de copiar para poder pegarlo en el paso 2
###
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "clinicName": "Las mascotas de Jesús",
  "firstName": "Jesús",
  "lastName": "Contreras Carrero",
  "email": "jesuscsantiago27@gmail.com",
  "phone": "+34-651245465",
  "password": "Mi_super_contraseña_1"
}

###

# Paso intermedio si necesitamos re-enviar el email de verificación de email
#   El cual nos dará el token de nuevo con una caducidad de 1 hora.
#   En el debemos de enviar el mismo email que usamos en el paso 1

###
POST http://localhost:8080/auth/resend-verification
Content-Type: application/json

{
  "email": "jesuscsantiago27@gmail.com"
}

###

# Paso 2:
#   Con el token que copialos lo pegalo en el siguiente endpoint y ejecutado.
#   Esto nos dará una respuesta parecida a esto:
#       {
#         "accessToken": "JWT_TEMPORAL_ONBOARDING", // Debemos de copiar este token ahora
#           "refreshToken": null,
#           "tokenType": "Bearer",
#           "expiresIn": 3600,
#           "user": {
#               "userId": "...",
#               "employeeId": null,
#               "clinicId": "...",
#               "email": "...",
#               "role": "CLINIC_OWNER"
#             }
#       }
#   Con esta respuesta debemos de copiar el token de accessToken, que lo usaremos en el paso 3.

GET http://localhost:8080/auth/verify-email?token=77736f87-7e3f-4595-8035-d83355f8fc58

###

#   Paso intermedio por si el usuario, pudo verificar su correo, pero no pudo completar el registro de la clinica
#   y se le vencio el token.
#
#   La idea en este paso es que el usuario tenga que hacer login y en la respuesta del login, tendrá un atributo
#   llamado nextStep, el cual si es null tiene acceso completo a la app, si es "COMPLETE-SETUP" se le redifige a la
#   pantalla del paso 3, para que termine de cargar los datos de la clinica.

###
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "email": "jesuscsantiago27@gmail.com",
  "password": "Mi_super_contraseña_1"
}

###

# Paso 3:
#   En este paso completaremos el registro de la clinica, con el terminaremos de llenar los datos de la clinica.
#   Los cuales son:
#       legalName               : String
#       legalNumber             : String
#       legalType               : Enum [AUTONOMO SOCIEDAD_LIMITADA SOCIEDAD_ANONIMA SOCIEDAD_CIVIL COMUNIDAD_DE_BIENES OTHER]
#       address                 : String
#       city                    : String
#       codePostal              : String
#       phone                   : String
#       email                   : String
#       logoUrl                 : String
#       schedulesOpenDays       : String
#       scheduleOpenTime        : LocalTime
#       scheduleCloseTime       : LocalTime
#       scheduleNotes           : String
#       ownerDocumentId         : Enum [DNI, NIE, PASAPORTE]
#       ownerDocumentNumber     : String
#       ownerAddress            : String
#       ownerCity               : String
#       ownerPostalCode         : String
#       ownerHireDate           : LocalDate
#       ownerAvatarUrl          : String
#       ownerSpeciality         : String

